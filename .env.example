# ============================================
# Research Crew - Environment Configuration
# ============================================

# ===========================================
# OPTION 1: Use Gemini for everything (no OpenAI needed)
# ===========================================
EMBEDDING_PROVIDER=gemini
GOOGLE_API_KEY=your-google-api-key-here

# CrewAI LLM Configuration (uses Gemini)
OPENAI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_API_KEY=OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL_NAME=gemini/gemini-2.0-flash

# ===========================================
# OPTION 2: Use OpenAI for everything
# ===========================================
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL_NAME=gpt-4o-mini

# ===========================================
# OPTION 3: Mix - Gemini embeddings + OpenAI LLM
# ===========================================
# EMBEDDING_PROVIDER=gemini
# GOOGLE_API_KEY=your-google-api-key-here
# OPENAI_API_KEY=OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_MODEL_NAME=gpt-4o-mini

# Optional: Chunking Configuration
CHUNK_SIZE=800
CHUNK_OVERLAP=200
